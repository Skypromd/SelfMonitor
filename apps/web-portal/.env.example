# Copy to .env.local for local dev:  cp .env.example .env.local
# Next.js inlines NEXT_PUBLIC_* at build time — set these in CI/CD for production.

# Same-origin /api → rewrites to gateway (see next.config.js). Avoid http://localhost:8000 in NEXT_PUBLIC_* unless nginx CORS covers every route you need from the browser.
NEXT_PUBLIC_API_GATEWAY_URL=/api

NEXT_PUBLIC_AUTH_SERVICE_URL=/api/auth
NEXT_PUBLIC_LOCALIZATION_SERVICE_URL=/api/localization
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=/api/analytics
NEXT_PUBLIC_ADVICE_SERVICE_URL=/api/advice
NEXT_PUBLIC_PROFILE_SERVICE_URL=/api/profile
NEXT_PUBLIC_DOCUMENTS_SERVICE_URL=/api/documents
NEXT_PUBLIC_BANKING_SERVICE_URL=/api/banking
NEXT_PUBLIC_BILLING_SERVICE_URL=/api/billing
NEXT_PUBLIC_PARTNER_REGISTRY_URL=/api/partners
NEXT_PUBLIC_COMPLIANCE_SERVICE_URL=/api/compliance
NEXT_PUBLIC_CALENDAR_SERVICE_URL=/api/calendar
NEXT_PUBLIC_REFERRAL_SERVICE_URL=/api/referrals
NEXT_PUBLIC_CATEGORIZATION_SERVICE_URL=/api/categorization
NEXT_PUBLIC_TRANSACTIONS_SERVICE_URL=/api/transactions
NEXT_PUBLIC_INVOICE_SERVICE_URL=/api/invoices
NEXT_PUBLIC_TAX_ENGINE_URL=/api/tax
NEXT_PUBLIC_QNA_SERVICE_URL=/api/qna
NEXT_PUBLIC_AI_AGENT_SERVICE_URL=/api/agent

# Optional: i18n without running gateway
# NEXT_PUBLIC_SKIP_I18N_FETCH=1

# Operator subdomain practolog — separate origin (see middleware.ts, lib/adminSurface.ts)
# NEXT_PUBLIC_ADMIN_SUBDOMAIN_ENABLED=1
# NEXT_PUBLIC_ADMIN_HOST=practolog.localhost
# NEXT_PUBLIC_CLIENT_ORIGIN=http://localhost:3000
# NEXT_PUBLIC_ADMIN_ORIGIN=http://practolog.localhost:3000
