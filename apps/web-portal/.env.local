# These variables are used by Next.js to expose them to the browser.
# All backend requests go through the API Gateway to avoid CORS issues.

# API Gateway (proxy — no CORS)
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8000/api

# Route everything through gateway — no direct service ports in browser
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8000/api/auth
NEXT_PUBLIC_LOCALIZATION_SERVICE_URL=http://localhost:8000/api/localization
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=http://localhost:8000/api/analytics
NEXT_PUBLIC_ADVICE_SERVICE_URL=http://localhost:8000/api/advice
NEXT_PUBLIC_PROFILE_SERVICE_URL=http://localhost:8000/api/profile
NEXT_PUBLIC_DOCUMENTS_SERVICE_URL=http://localhost:8000/api/documents
NEXT_PUBLIC_BANKING_SERVICE_URL=http://localhost:8000/api/banking
NEXT_PUBLIC_BILLING_SERVICE_URL=http://localhost:8000/api/billing
