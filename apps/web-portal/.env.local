# These variables are used by Next.js to expose them to the browser.
# They allow us to easily change the service URLs without changing the code.

# All backend requests now go through the API Gateway
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:8080/api

# Local dev overrides (services running without Docker)
NEXT_PUBLIC_AUTH_SERVICE_URL=http://localhost:8001
NEXT_PUBLIC_LOCALIZATION_SERVICE_URL=http://localhost:8012
NEXT_PUBLIC_ANALYTICS_SERVICE_URL=http://localhost:8009
NEXT_PUBLIC_ADVICE_SERVICE_URL=http://localhost:8010
NEXT_PUBLIC_PROFILE_SERVICE_URL=http://localhost:8005
NEXT_PUBLIC_PARTNER_REGISTRY_URL=http://localhost:8016
NEXT_PUBLIC_DOCUMENTS_SERVICE_URL=http://localhost:8006
NEXT_PUBLIC_INVOICE_SERVICE_URL=http://localhost:8013
NEXT_PUBLIC_CALENDAR_SERVICE_URL=http://localhost:8015
NEXT_PUBLIC_REFERRAL_SERVICE_URL=http://localhost:8017
NEXT_PUBLIC_AI_AGENT_SERVICE_URL=http://localhost:8019
NEXT_PUBLIC_CATEGORIZATION_SERVICE_URL=http://localhost:8020

NEXT_PUBLIC_BANKING_SERVICE_URL=http://localhost:8015
