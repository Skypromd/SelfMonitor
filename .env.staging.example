# Staging — copy to .env.staging (never commit).
#   docker compose --env-file .env.staging -f docker-compose.yml -f docker-compose.staging.yml up -d
#
# Use Stripe test keys, staging domains, and shorter backup retention than prod.

PUBLIC_API_BASE=https://api-staging.example.com
FRONTEND_URL=https://app-staging.example.com

POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=db_user_profile

AUTH_SECRET_KEY=change-me-staging-different-from-prod

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

BACKUP_RETENTION_DAYS=7
BACKUP_INTERVAL_SEC=86400
