# MyNetTax — production env template (DO NOT commit real values).
# Usage:
#   cp .env.prod.example .env.prod
#   docker compose --env-file .env.prod -f docker-compose.yml -f docker-compose.prod.yml up -d
#
# Sensitive values: prefer root-only files on host or a secrets manager; never commit .env.prod.

# --- Domains & URLs (edge TLS terminates at Cloudflare / LB / Caddy) ---
PUBLIC_API_BASE=https://api.example.com
FRONTEND_URL=https://app.example.com

# --- PostgreSQL (compose service postgres-master, hostname postgres-master) ---
POSTGRES_USER=user
POSTGRES_PASSWORD=change-me-strong
POSTGRES_DB=db_user_profile

# --- Auth / JWT (required for non-dev; fail-fast where implemented) ---
AUTH_SECRET_KEY=change-me-min-32-chars-random

# --- Stripe (billing-service); leave empty only for mock/dev ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_GROWTH=
STRIPE_PRICE_PRO=
STRIPE_PRICE_BUSINESS=

# Stripe Dashboard webhook URL (after nginx strip prefix):
#   POST https://<public-domain>/api/billing/webhook

# --- Billing persistence (set by docker-compose.prod.yml) ---
# BILLING_DB_PATH=/data/billing.db

# --- MinIO / S3 (replace defaults before prod) ---
# MINIO_ROOT_USER=
# MINIO_ROOT_PASSWORD=

# --- Backup sidecar (profile backup) ---
BACKUP_RETENTION_DAYS=14
BACKUP_INTERVAL_SEC=86400

# --- Optional: OpenAI / voice ---
# OPENAI_API_KEY=
